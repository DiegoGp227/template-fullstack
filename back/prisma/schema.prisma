// RM: replace models with your own schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// RM: Example model — replace with your own
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
